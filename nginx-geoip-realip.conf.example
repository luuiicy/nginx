# GeoIP2 数据库路径（需挂载 MaxMind .mmdb 文件）
geoip2 /etc/nginx/geoip/GeoLite2-Country.mmdb {
    $geoip2_country_code country iso_code;
    $geoip2_country_name country names en;
}

geoip2 /etc/nginx/geoip/GeoLite2-City.mmdb {
    $geoip2_city        city names en;
    $geoip2_latitude    location latitude;
    $geoip2_longitude   location longitude;
}

server {
    listen 80;
    server_name example.com;

    # Real IP：从 CDN / 负载均衡器还原真实客户端 IP
    # 将你的上游代理 IP 段填在这里
    set_real_ip_from  10.0.0.0/8;
    set_real_ip_from  172.16.0.0/12;
    set_real_ip_from  192.168.0.0/16;
    # Cloudflare IP 段示例
    set_real_ip_from  103.21.244.0/22;
    real_ip_header    X-Forwarded-For;
    real_ip_recursive on;

    # 按国家封锁示例（封锁 CN 以外直接返回 403）
    # if ($geoip2_country_code != "CN") {
    #     return 403;
    # }

    location / {
        # 把地理信息透传给后端
        proxy_set_header X-Real-IP        $remote_addr;
        proxy_set_header X-Country-Code   $geoip2_country_code;
        proxy_set_header X-Country-Name   $geoip2_country_name;
        proxy_set_header X-City           $geoip2_city;

        proxy_pass http://backend;
    }
}
